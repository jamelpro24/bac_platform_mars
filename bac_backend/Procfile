import os,django;os.environ.setdefault('DJANGO_SETTINGS_MODULE','bac_backend.settings');django.setup()
from accounts.models import User
try:
    u = User.objects.get(username='admin')
    u.set_password('admin123')
    u.is_active = True
    u.role = 'admin'
    u.centre = 'centre'
    u.save()
    print('admin password updated')
except User.DoesNotExist:
    u = User.objects.create_superuser('admin', 'admin@example.com', 'admin123')
    u.role = 'admin'
    u.centre = 'centre'
    u.save()
    print('admin superuser created')
try:
    u = User.objects.get(username='jamel')
    u.set_password('admin123')
    u.is_active = True
    u.save()
    print('jamel password updated')
except User.DoesNotExist:
    print('jamel not found')
